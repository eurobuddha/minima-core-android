<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@color/core_surface"
    android:paddingHorizontal="16dp"
    android:paddingVertical="15dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/balance_tokenname"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:ellipsize="end"
            android:textAppearance="@style/TextAppearance.MinimaCore.BodyStrong" />

        <TextView
            android:id="@+id/balance_tokenid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:maxLines="1"
            android:ellipsize="middle"
            android:textAppearance="@style/TextAppearance.MinimaCore.Caption"
            android:textColor="@color/core_text_faint" />
    </LinearLayout>

    <TextView
        android:id="@+id/balance_tokenamount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:gravity="end"
        android:fontFeatureSettings="tnum"
        android:textAppearance="@style/TextAppearance.MinimaCore.BodyStrong" />
</LinearLayout>
