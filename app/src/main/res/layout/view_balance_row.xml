<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@color/core_surface"
    android:paddingHorizontal="16dp"
    android:paddingVertical="13dp">

    <!-- token icon (identicon fallback, real icon loaded over) + web-validation badge -->
    <FrameLayout
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="12dp"
        android:background="@drawable/bg_token_tile">

        <ImageView
            android:id="@+id/balance_tokenicon"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="Token icon" />

        <ImageView
            android:id="@+id/balance_tokenbadge"
            android:layout_width="15dp"
            android:layout_height="15dp"
            android:layout_gravity="bottom|end"
            android:visibility="gone"
            android:contentDescription="Web validated" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/balance_tokenname"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:ellipsize="end"
            android:textAppearance="@style/TextAppearance.MinimaCore.BodyStrong" />

        <TextView
            android:id="@+id/balance_tokenid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:maxLines="1"
            android:ellipsize="middle"
            android:textAppearance="@style/TextAppearance.MinimaCore.Caption"
            android:textColor="@color/core_text_faint" />
    </LinearLayout>

    <TextView
        android:id="@+id/balance_tokenamount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:gravity="end"
        android:fontFeatureSettings="tnum"
        android:textAppearance="@style/TextAppearance.MinimaCore.BodyStrong" />
</LinearLayout>
