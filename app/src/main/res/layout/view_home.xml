<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/core_bg">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===== NODE ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Node"
                android:textAppearance="@style/TextAppearance.MinimaCore.Eyebrow" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout style="@style/HomeRow">
                        <View android:layout_width="8dp" android:layout_height="8dp"
                            android:layout_gravity="center_vertical" android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_dot" />
                        <TextView style="@style/HomeRow.Label" android:text="Status" />
                        <TextView style="@style/HomeRow.Value" android:text="Online"
                            android:textColor="@color/status_good" />
                    </LinearLayout>

                    <View style="@style/HomeDivider" />
                    <LinearLayout style="@style/HomeRow">
                        <TextView style="@style/HomeRow.Label" android:text="Block" />
                        <TextView android:id="@+id/home_blocks" style="@style/HomeRow.Value" />
                    </LinearLayout>

                    <View style="@style/HomeDivider" />
                    <LinearLayout style="@style/HomeRow">
                        <TextView style="@style/HomeRow.Label" android:text="Block time" />
                        <TextView android:id="@+id/home_block_time" style="@style/HomeRow.Value" />
                    </LinearLayout>

                    <View style="@style/HomeDivider" />
                    <LinearLayout style="@style/HomeRow">
                        <TextView style="@style/HomeRow.Label" android:text="Connections" />
                        <TextView android:id="@+id/home_connections" style="@style/HomeRow.Value" />
                    </LinearLayout>

                    <View style="@style/HomeDivider" />
                    <LinearLayout style="@style/HomeRow">
                        <TextView style="@style/HomeRow.Label" android:text="Random peer" />
                        <TextView android:id="@+id/home_peers" style="@style/HomeRow.Value"
                            android:maxLines="1" android:ellipsize="middle" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ===== IDENTITY ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp"
                android:text="Identity"
                android:textAppearance="@style/TextAppearance.MinimaCore.Eyebrow" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Key uses"
                        android:textAppearance="@style/TextAppearance.MinimaCore.Caption" />
                    <TextView
                        android:id="@+id/home_keyuses"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Connecting…"
                        android:textAppearance="@style/TextAppearance.MinimaCore.Numeral" />

                    <View style="@style/HomeDivider" android:layout_marginTop="14dp" />
                    <LinearLayout style="@style/HomeRow">
                        <TextView style="@style/HomeRow.Label" android:text="Minima" />
                        <TextView android:id="@+id/home_version" style="@style/HomeRow.Value" />
                    </LinearLayout>

                    <View style="@style/HomeDivider" />
                    <LinearLayout style="@style/HomeRow">
                        <TextView style="@style/HomeRow.Label" android:text="APK version" />
                        <TextView android:id="@+id/home_app_version" style="@style/HomeRow.Value" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_tester"
                style="@style/Widget.MinimaCore.Button.Text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_gravity="start"
                android:text="Tester" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
