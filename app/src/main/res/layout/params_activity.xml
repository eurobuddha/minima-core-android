<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/params_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/core_bg">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/core_surface"
        app:titleTextColor="@color/core_text"
        app:titleTextAppearance="@style/TextAppearance.MinimaCore.Title"
        android:minHeight="?attr/actionBarSize"
        android:theme="?attr/actionBarTheme" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Startup parameters"
                android:textAppearance="@style/TextAppearance.MinimaCore.Display" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Configure how the node starts. Changes take effect when the node restarts."
                android:textAppearance="@style/TextAppearance.MinimaCore.Body"
                android:textColor="@color/core_text_mid"
                android:lineSpacingMultiplier="1.3" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/params_switch_server"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Server mode (-server)"
                android:textAppearance="@style/TextAppearance.MinimaCore.Body"
                android:textColor="@color/core_text" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Accept incoming connections instead of client-only. Needs a reachable port (router forward / hotspot)."
                android:textAppearance="@style/TextAppearance.MinimaCore.Body"
                android:textSize="12sp"
                android:textColor="@color/core_text_mid" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/params_switch_megammr"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="MegaMMR (-megammr)"
                android:textAppearance="@style/TextAppearance.MinimaCore.Body"
                android:textColor="@color/core_text" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Keep the full Mega MMR so this node can serve seed resyncs. Uses significantly more RAM and storage."
                android:textAppearance="@style/TextAppearance.MinimaCore.Body"
                android:textSize="12sp"
                android:textColor="@color/core_text_mid" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/params_switch_rpc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Enable RPC (-rpcenable)"
                android:textAppearance="@style/TextAppearance.MinimaCore.Body"
                android:textColor="@color/core_text" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="HTTP RPC interface on port 11005. Only enable if you know you need it - anything that can reach the port can command the node."
                android:textAppearance="@style/TextAppearance.MinimaCore.Body"
                android:textSize="12sp"
                android:textColor="@color/core_text_mid" />

            <TextView style="@style/FormLabel" android:text="Extra arguments (advanced)" />

            <EditText
                android:id="@+id/params_extra"
                style="@style/FormField"
                android:minLines="2"
                android:gravity="top|start"
                android:inputType="textMultiLine|textNoSuggestions"
                android:hint="-p2pnodes host:port -txpowdbstore 3 …" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Space-separated flags passed to the node at boot. Wipe/seed flags (-clean, -genesis, -solo, -seed, -anyseed, -dbpassword) and app-managed flags (-data, -basefolder, -conf, -server, -isclient) are not allowed here."
                android:textAppearance="@style/TextAppearance.MinimaCore.Body"
                android:textSize="12sp"
                android:textColor="@color/core_text_mid" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/params_button_save"
                style="@style/Widget.MinimaCore.Button.Outlined"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="20dp"
                android:text="Save" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/params_button_save_restart"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:text="Save &amp; Restart Node" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
