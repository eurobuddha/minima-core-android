<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/sync_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/core_bg">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/core_surface"
        android:elevation="0dp"
        app:titleTextColor="@color/core_text"
        app:titleTextAppearance="@style/TextAppearance.MinimaCore.Title"
        android:minHeight="?attr/actionBarSize"
        android:theme="?attr/actionBarTheme" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/core_outline" />

    <RelativeLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:id="@+id/terminal_bottomrow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/core_surface"
            android:padding="10dp">

            <EditText
                android:id="@+id/terminal_input"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:singleLine="true"
                android:background="@drawable/bg_token_tile"
                android:paddingHorizontal="14dp"
                android:paddingVertical="10dp"
                android:fontFamily="monospace"
                android:hint="Enter command"
                android:textColor="@color/core_text"
                android:textColorHint="@color/core_text_faint"
                android:textSize="14sp"
                android:imeOptions="actionSend" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/terminal_send"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_marginStart="8dp"
                android:text="Run" />
        </LinearLayout>

        <ScrollView
            android:id="@+id/terminal_scroller"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_above="@+id/terminal_bottomrow"
            android:scrollbars="none"
            android:background="@color/core_bg">

            <TextView
                android:id="@+id/terminal_maintext"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:scrollHorizontally="false"
                android:gravity="bottom"
                android:textIsSelectable="true"
                android:focusable="true"
                android:longClickable="true"
                android:textColor="@color/core_text"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.35" />
        </ScrollView>
    </RelativeLayout>
</LinearLayout>
