<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/newwallet_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/core_bg">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/core_surface"
        app:titleTextColor="@color/core_text"
        app:titleTextAppearance="@style/TextAppearance.MinimaCore.Title"
        android:minHeight="?attr/actionBarSize"
        android:theme="?attr/actionBarTheme" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Your recovery seed"
                android:textAppearance="@style/TextAppearance.MinimaCore.Display" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Write these words down and keep them safe. Anyone with this seed controls your funds — and it cannot be recovered if lost."
                android:textAppearance="@style/TextAppearance.MinimaCore.Body"
                android:textColor="@color/core_text_mid"
                android:lineSpacingMultiplier="1.3" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:strokeColor="@color/minima_orange"
                app:strokeWidth="1dp">

                <TextView
                    android:id="@+id/newwallet_seed"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textIsSelectable="true"
                    android:gravity="center"
                    android:fontFamily="monospace"
                    android:textColor="@color/core_text"
                    android:textSize="17sp"
                    android:lineSpacingMultiplier="1.5" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/newwallet_button_proceed"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="28dp"
                android:text="I've saved it — Proceed" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
