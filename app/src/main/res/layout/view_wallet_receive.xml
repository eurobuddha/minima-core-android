<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:background="@color/core_bg"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="18dp"
        android:text="Scan to receive"
        android:textAppearance="@style/TextAppearance.MinimaCore.Eyebrow" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="20dp"
        app:strokeWidth="0dp"
        app:contentPadding="18dp"
        xmlns:app="http://schemas.android.com/apk/res-auto">

        <ImageView
            android:id="@+id/wallet_receive_qrcode"
            android:layout_width="240dp"
            android:layout_height="240dp"
            android:contentDescription="Receive QR code" />
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/wallet_receive_address"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:gravity="center"
        android:textIsSelectable="true"
        android:fontFamily="monospace"
        android:textColor="@color/core_text"
        android:textSize="13sp"
        android:lineSpacingMultiplier="1.2" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/wallet_receive_changeaddress"
        style="@style/Widget.MinimaCore.Button.Outlined"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_marginTop="20dp"
        android:text="Get Address" />
</LinearLayout>
