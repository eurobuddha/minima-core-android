<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/sync_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/core_bg">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/core_surface"
        app:titleTextColor="@color/core_text"
        app:titleTextAppearance="@style/TextAppearance.MinimaCore.Title"
        android:minHeight="?attr/actionBarSize"
        android:theme="?attr/actionBarTheme" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Resync node"
                android:textAppearance="@style/TextAppearance.MinimaCore.Display" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Choose a Minima MegaMMR node to resync from. Use the format host:port."
                android:textAppearance="@style/TextAppearance.MinimaCore.Body"
                android:textColor="@color/core_text_mid"
                android:lineSpacingMultiplier="1.3" />

            <TextView style="@style/FormLabel" android:text="MegaMMR node" />

            <EditText
                android:id="@+id/seed_sync_host"
                style="@style/FormField"
                android:hint="host:port" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/seed_sync_proceed"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="28dp"
                android:text="Resync Node" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
