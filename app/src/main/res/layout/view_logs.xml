<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/core_bg">

    <!-- Controls: pause / clear / share + filter -->
    <LinearLayout
        android:id="@+id/logs_controlrow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/core_surface"
        android:padding="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/logs_pause"
            style="@style/Widget.MinimaCore.Button.Outlined"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:minWidth="0dp"
            android:paddingHorizontal="12dp"
            android:text="Pause" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/logs_clear"
            style="@style/Widget.MinimaCore.Button.Outlined"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:minWidth="0dp"
            android:layout_marginStart="6dp"
            android:paddingHorizontal="12dp"
            android:text="Clear" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/logs_share"
            style="@style/Widget.MinimaCore.Button.Outlined"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:minWidth="0dp"
            android:layout_marginStart="6dp"
            android:paddingHorizontal="12dp"
            android:text="Share" />

        <EditText
            android:id="@+id/logs_filter"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:singleLine="true"
            android:background="@drawable/bg_token_tile"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp"
            android:fontFamily="monospace"
            android:hint="Filter"
            android:textColor="@color/core_text"
            android:textColorHint="@color/core_text_faint"
            android:textSize="13sp"
            android:imeOptions="actionDone" />
    </LinearLayout>

    <!-- Verbosity chips: each runs the node's `logs <key>:true|false` command -->
    <HorizontalScrollView
        android:id="@+id/logs_chiprow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/logs_controlrow"
        android:background="@color/core_surface"
        android:scrollbars="none"
        android:paddingHorizontal="8dp"
        android:paddingBottom="6dp">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/logs_chips"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:singleLine="true" />
    </HorizontalScrollView>

    <ScrollView
        android:id="@+id/logs_scroller"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/logs_chiprow"
        android:scrollbars="none"
        android:background="@color/core_bg">

        <TextView
            android:id="@+id/logs_maintext"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:scrollHorizontally="false"
            android:gravity="bottom"
            android:textIsSelectable="true"
            android:focusable="true"
            android:longClickable="true"
            android:textColor="@color/core_text"
            android:textSize="12sp"
            android:lineSpacingMultiplier="1.3" />
    </ScrollView>
</RelativeLayout>
